<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext HTTP is permitted to support self-hosted LAN deployments where the
        user configures a local server address (e.g. http://192.168.1.x:9001).
        The default Capsule server always uses HTTPS.
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
